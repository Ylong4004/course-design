{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "编译全部（19个cpp）",
            "command": "C:\\MinGW\\bin\\g++.exe",
            "args": [
                "-std=c++11",
                "-Wall",
                "-g3",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/graph/adj_matrix.cpp",
                "${workspaceFolder}/src/graph/adj_list.cpp",
                "${workspaceFolder}/src/algorithms/queue.cpp",
                "${workspaceFolder}/src/algorithms/stack.cpp",
                "${workspaceFolder}/src/algorithms/union_find.cpp",
                "${workspaceFolder}/src/algorithms/priority_queue.cpp",
                "${workspaceFolder}/src/algorithms/traversal.cpp",
                "${workspaceFolder}/src/algorithms/shortest_path.cpp",
                "${workspaceFolder}/src/algorithms/spanning_tree.cpp",
                "${workspaceFolder}/src/algorithms/topological.cpp",
                "${workspaceFolder}/src/services/road_network.cpp",
                "${workspaceFolder}/src/services/congestion.cpp",
                "${workspaceFolder}/src/services/comparator.cpp",
                "${workspaceFolder}/src/services/file_io.cpp",
                "${workspaceFolder}/src/ui/menu.cpp",
                "${workspaceFolder}/src/ui/formatter.cpp",
                "${workspaceFolder}/src/ui/validator.cpp",
                "${workspaceFolder}/src/test/test_cases.cpp",
                "-o",
                "${workspaceFolder}/src/output/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译全部 19 个 cpp 文件"
        }
    ]
}
